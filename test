                    selected = "Select..."
                    HeaderLabel.Text = labelText .. ": " .. selected
                    expanded = false
                    Tween(DropFrame, {Size = UDim2.new(1, 0, 0, L.ELEM_H_SM)}, 0.15)
                    Tween(Arrow, {Rotation = 0}, 0.15)
                    BuildOptions()
                end,
            }, DropFrame)
        end

