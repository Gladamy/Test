function Aurora:CreateWindow(config)
    config   = config or {}
    local title    = config.Title    or "Aurora"
    local size     = config.Size     or UDim2.new(0, 620, 0, 420)
    local position = config.Position or UDim2.new(0.5, -310, 0.5, -210)

    -- Collect every persistent connection so they can all be torn down on close
    local windowConnections = {}

    -- ── Config persistence ────────────────────────────────────────────────
    -- configFile: path passed in config.ConfigFile, e.g. "MyScript_config.json"
    -- loadedData: the table read from disk at window creation time; elements
    --             with a matching Key read their saved value from here.
    local configFile  = config.ConfigFile or nil
    local configData  = configFile and loadFile(configFile) or {}
    local saveData    = {}   -- accumulates current values from keyed elements

    -- Call after any value changes to flush to disk immediately
    local function PersistSave()
        if configFile then saveFile(configFile, saveData) end
    end

    -- Public: overwrite the file right now with current element values
    -- (also called automatically on every element change when ConfigFile set)
    local function SaveConfig()
        if not configFile then
            warn("[Aurora] SaveConfig: no ConfigFile set on this window.")
            return
        end
        saveFile(configFile, saveData)
    end

    -- Public: re-read the file and push values back into every registered
    -- element.  Elements register a _loadFn when they have a Key.
    local elementLoaders = {}   -- key → function(value)

    local function LoadConfig()
        if not configFile then
            warn("[Aurora] LoadConfig: no ConfigFile set on this window.")
            return
        end
        local fresh = loadFile(configFile)
        for key, fn in pairs(elementLoaders) do
            if fresh[key] ~= nil then
                pcall(fn, fresh[key])
                saveData[key] = fresh[key]
            end
        end
    end

    local ScreenGui = Create("ScreenGui", {
        Name           = "AuroraUI",
        Parent         = LocalPlayer:WaitForChild("PlayerGui"),
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    })

    local MainFrame = Create("Frame", {
        Name             = "MainFrame",
        Parent           = ScreenGui,
        Position         = position,
        Size             = size,
        BackgroundColor3 = Aurora.Config.Theme.Background,
        BorderSizePixel  = 0,
        ClipsDescendants = true,
