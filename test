            TextXAlignment     = Enum.TextXAlignment.Left,
        })
        AddCorner(InputBox, UDim.new(0, 4))
        Create("UIPadding", {Parent = InputBox, PaddingLeft = UDim.new(0, 8)})

        InputBox.Focused:Connect(function()
