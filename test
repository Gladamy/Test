                end,
                -- [API] Replace the option list at runtime.
                SetOptions = function(newOptions)
                    options  = newOptions
                    selected = "Select..."
                    Label.Text = labelText .. ": " .. selected
                    expanded = false
                    Tween(DropdownFrame, {Size = UDim2.new(1, 0, 0, L.ELEM_H_SM)}, 0.15)
                    Tween(Arrow, {Rotation = 0}, 0.15)
                    BuildOptions()
                end,
            }, DropdownFrame)
        end

