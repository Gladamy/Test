        })

        local InputBox = Create("TextBox", {
            Parent             = frame,
            Position           = UDim2.new(0, 10, 0, 26),
            Size               = UDim2.new(1, -20, 0, 22),
            BackgroundColor3   = Aurora.Config.Theme.Surface,
            BorderSizePixel    = 0,
            Text               = "",
            PlaceholderText    = cfg.Placeholder or "Type here...",
