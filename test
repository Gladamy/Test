                    Tween(Arrow, {Rotation = 0}, 0.2)
                end
            end)

            return RegisterElement({
                Frame     = DropFrame,
                OnChanged = OnChanged,
                GetValue  = function() return selected end,
                SetValue  = function(val)
                    if table.find(options, val) then
                        selected         = val
                        HeaderLabel.Text = labelText .. ": " .. val
