                -- Clear existing buttons
                for _, b in ipairs(optionBtns) do b:Destroy() end
                optionBtns = {}
                OptionsFrame.Size = UDim2.new(1, 0, 0, #options * ROW_H)

                for i, option in ipairs(options) do
