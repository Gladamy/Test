--  Notification queue  (intentionally module-level / shared)
-- ─────────────────────────────────────────────

local notifQueue = {}

local function RepositionNotifs()
    for i, data in ipairs(notifQueue) do
        local targetY = -(i * (K.NOTIF_HEIGHT + K.NOTIF_GAP))
        Tween(data.frame, {Position = UDim2.new(1, K.NOTIF_X, 1, targetY)}, 0.25)
    end
end

