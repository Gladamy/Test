-- ─────────────────────────────────────────────
--  Signal — lightweight pub/sub event system
-- ─────────────────────────────────────────────

local Signal = {}
Signal.__index = Signal

function Signal.new()
    return setmetatable({_handlers = {}, _counter = 0}, Signal)
end

function Signal:Connect(fn)
    self._counter = self._counter + 1
    local id = self._counter
    self._handlers[id] = fn
    return {
        Disconnect = function()
            self._handlers[id] = nil
        end
    }
end

function Signal:Fire(...)
    for _, fn in pairs(self._handlers) do
        pcall(fn, ...)
    end
end

-- ─────────────────────────────────────────────
--  Minimal JSON encoder / decoder
--  No external dependencies. Handles the value
--  types Aurora elements actually use:
--    boolean, number, string,
--    Color3  → stored as {__t="Color3",r,g,b}
--    KeyCode → stored as {__t="KeyCode",name}
--    array   → stored as JSON array
-- ─────────────────────────────────────────────

local JSON = {}

local function jsonEncode(val)
    local t = type(val)
    if t == "boolean" then
        return val and "true" or "false"
    elseif t == "number" then
        return tostring(val)
    elseif t == "string" then
        -- Escape special characters
        val = val:gsub('\\', '\\\\')
                 :gsub('"',  '\\"')
                 :gsub('\n', '\\n')
                 :gsub('\r', '\\r')
                 :gsub('\t', '\\t')
        return '"' .. val .. '"'
    elseif t == "table" then
        -- Check for userdata wrappers we inserted ourselves
        if val.__t == "Color3" then
            return string.format('{"__t":"Color3","r":%.6f,"g":%.6f,"b":%.6f}',
                val.r, val.g, val.b)
        elseif val.__t == "KeyCode" then
            return string.format('{"__t":"KeyCode","name":"%s"}', val.name)
        end
        -- Plain array (sequential integer keys only)
        local parts = {}
        for i, v in ipairs(val) do
            parts[i] = jsonEncode(v)
        end
        return "[" .. table.concat(parts, ",") .. "]"
    else
        return "null"
    end
end

local function jsonDecode(s)
    s = s:match("^%s*(.-)%s*$")   -- trim

    if s == "true"  then return true  end
    if s == "false" then return false end
    if s == "null"  then return nil   end

    -- Number
    local num = tonumber(s)
    if num then return num end

    -- String
    if s:sub(1,1) == '"' then
        local inner = s:match('^"(.*)"$')
        inner = inner:gsub('\\"', '"')
                     :gsub('\\n', '\n')
                     :gsub('\\r', '\r')
                     :gsub('\\t', '\t')
                     :gsub('\\\\', '\\')
        return inner
    end

    -- Array  [ v, v, v ]
    if s:sub(1,1) == "[" then
        local body = s:match("^%[(.*)%]$")
        local arr  = {}
        if body and body ~= "" then
            -- Simple single-level split on commas not inside {} or ""
            -- Sufficient for the flat arrays Aurora saves (string arrays)
            local depth = 0
            local cur   = ""
            for i = 1, #body do
                local ch = body:sub(i, i)
                if ch == "{" or ch == "[" then depth = depth + 1
                elseif ch == "}" or ch == "]" then depth = depth - 1 end
                if ch == "," and depth == 0 then
                    arr[#arr + 1] = jsonDecode(cur:match("^%s*(.-)%s*$"))
                    cur = ""
                else
                    cur = cur .. ch
                end
            end
            if cur:match("%S") then
                arr[#arr + 1] = jsonDecode(cur:match("^%s*(.-)%s*$"))
            end
        end
        return arr
    end

    -- Object  { ... }
    if s:sub(1,1) == "{" then
        local body = s:match("^%{(.*)%}$")
        local obj  = {}
        if body and body ~= "" then
            -- Split into key:value pairs respecting nesting
            local depth  = 0
            local inStr  = false
            local cur    = ""
            local pairs_ = {}
            for i = 1, #body do
                local ch = body:sub(i, i)
                if ch == '"' and body:sub(i-1, i-1) ~= "\\" then
                    inStr = not inStr
                end
                if not inStr then
                    if ch == "{" or ch == "[" then depth = depth + 1
                    elseif ch == "}" or ch == "]" then depth = depth - 1 end
                end
                if ch == "," and depth == 0 and not inStr then
                    pairs_[#pairs_ + 1] = cur:match("^%s*(.-)%s*$")
                    cur = ""
                else
                    cur = cur .. ch
                end
            end
            if cur:match("%S") then
                pairs_[#pairs_ + 1] = cur:match("^%s*(.-)%s*$")
            end
            for _, pair in ipairs(pairs_) do
                local k, v = pair:match('^"([^"]+)"%s*:%s*(.+)$')
                if k then obj[k] = jsonDecode(v) end
            end
        end
        -- Re-hydrate Aurora-specific types
        if obj.__t == "Color3" then
            return Color3.new(obj.r or 0, obj.g or 0, obj.b or 0)
        elseif obj.__t == "KeyCode" then
            return Enum.KeyCode[obj.name] or Enum.KeyCode.Unknown
        end
        return obj
    end

    return nil
end

-- Wrap a Lua value into a JSON-serialisable form
local function toJsonVal(v)
    local t = typeof(v)
    if t == "boolean" or t == "number" or t == "string" then
        return v
    elseif t == "Color3" then
        return {__t = "Color3", r = v.R, g = v.G, b = v.B}
    elseif t == "EnumItem" then   -- KeyCode
        return {__t = "KeyCode", name = v.Name}
    elseif t == "table" then
        -- Assume plain string array (MultiSelect values)
        local out = {}
        for i, item in ipairs(v) do out[i] = toJsonVal(item) end
        return out
    end
    return nil
end

JSON.encode = jsonEncode
JSON.decode = jsonDecode
JSON.wrap   = toJsonVal

-- ─────────────────────────────────────────────
--  Config persistence
--  Uses executor's writefile / readfile.
--  Falls back silently if not available.
-- ─────────────────────────────────────────────

-- Checks whether executor filesystem APIs exist
local function fsAvailable()
    return type(writefile) == "function" and type(readfile) == "function"
end

-- Loads the stored table for a given filename, or {} on miss/error
local function loadFile(path)
    if not fsAvailable() then return {} end
    local ok, raw = pcall(readfile, path)
    if not ok or type(raw) ~= "string" or raw == "" then return {} end
    local decoded = jsonDecode(raw)
    return type(decoded) == "table" and decoded or {}
end

-- Saves a table to a file as JSON
local function saveFile(path, tbl)
    if not fsAvailable() then return end
    pcall(writefile, path, jsonEncode(tbl))
end

-- ─────────────────────────────────────────────
--  Utility
-- ─────────────────────────────────────────────

local function Create(className, props)
    local inst = Instance.new(className)
    for k, v in pairs(props or {}) do inst[k] = v end
    return inst
end

local function Tween(inst, props, duration, easingStyle, easingDir)
    local info = TweenInfo.new(
        duration    or Aurora.Config.Animation.Duration,
        easingStyle or Aurora.Config.Animation.Easing,
        easingDir   or Aurora.Config.Animation.Direction
    )
    local t = TweenService:Create(inst, info, props)
    t:Play()
    return t
end

local function AddCorner(parent, radius)
    return Create("UICorner", {
        CornerRadius = radius or Aurora.Config.CornerRadius,
        Parent       = parent,
    })
end

local function AddShadow(parent, intensity)
    return Create("ImageLabel", {
        Name                   = "Shadow",
        Parent                 = parent,
        AnchorPoint            = Vector2.new(0.5, 0.5),
        Position               = UDim2.new(0.5, 0, 0.5, 4),
        Size                   = UDim2.new(1, 24, 1, 24),
        BackgroundTransparency = 1,
        Image                  = "rbxassetid://6014261993",
        ImageColor3            = Color3.new(0, 0, 0),
        ImageTransparency      = Aurora.Config.ShadowTransparency * (intensity or 1),
        ScaleType              = Enum.ScaleType.Slice,
        SliceCenter            = Rect.new(49, 49, 450, 450),
        ZIndex                 = parent.ZIndex - 1,
    })
end

local function MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging, dragStart, startPos = false, nil, nil
    local conns = {}

    conns[1] = handle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = inp.Position
            startPos  = frame.Position
        end
    end)

    conns[2] = UserInputService.InputChanged:Connect(function(inp)
        if dragging and (
            inp.UserInputType == Enum.UserInputType.MouseMovement or
            inp.UserInputType == Enum.UserInputType.Touch
        ) then
            local d = inp.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,  startPos.X.Offset + d.X,
                startPos.Y.Scale,  startPos.Y.Offset + d.Y
            )
        end
    end)

    conns[3] = UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return conns
end

