    -- ── Window object ─────────────────────────────────────────────────────

    local Window = {
        ScreenGui        = ScreenGui,
        MainFrame        = MainFrame,
        TabContainer     = TabContainer,
        ContentContainer = ContentContainer,
        Tabs             = {},
        ActiveTab        = nil,
        OnTabChanged     = Signal.new(),  -- fires (newTab, oldTab)
        SaveConfig       = SaveConfig,
        LoadConfig       = LoadConfig,
    }

    function Window:SelectTab(index)
        local tab = self.Tabs[index]
        if tab and tab.Activate then tab.Activate() end
    end

    function Window:Destroy()
        for _, c in ipairs(windowConnections) do
            if c and c.Disconnect then c:Disconnect() end
        end
        ScreenGui:Destroy()
    end

    -- ──────────────────────────────────────────────────────────────────────
    --  Element builder helpers
    --  Defined once here and shared by every tab created in this window.
    -- ──────────────────────────────────────────────────────────────────────

    -- Returns a plain background frame used by most simple elements
    local function BaseFrame(tabContent, height)
        local f = Create("Frame", {
            Parent           = tabContent,
            Size             = UDim2.new(1, 0, 0, height),
            BackgroundColor3 = Aurora.Config.Theme.Background,
            BorderSizePixel  = 0,
        })
        AddCorner(f, UDim.new(0, 4))
        return f
    end

    -- Attaches Destroy / SetVisible / SetEnabled / tooltip / config to every element
    local function RegisterElement(tab, emptyState, element, frame, cfg)
        cfg = cfg or {}
        if #tab.Elements == 0 then
            emptyState.Visible = false
        end
        table.insert(tab.Elements, element)
        tab.OnElementAdded:Fire(element)

        -- ── Tooltip ───────────────────────────────────────────────────────
        if cfg.Tooltip and cfg.Tooltip ~= "" then
            AttachTooltip(frame, cfg.Tooltip)
        end

        -- ── Config persistence ────────────────────────────────────────────
        -- If the element has a Key and a GetValue/SetValue, hook it up.
        if cfg.Key and element.GetValue and element.SetValue then
            local key = cfg.Key

            -- Load saved value immediately if one exists
            if configData[key] ~= nil then
                pcall(element.SetValue, configData[key])
                saveData[key] = configData[key]
            elseif element.GetValue then
                -- Seed saveData with the element's current default
                saveData[key] = JSON.wrap(element.GetValue())
            end

            -- Register loader for LoadConfig()
            elementLoaders[key] = function(val)
                pcall(element.SetValue, val)
            end

            -- Wrap OnChanged to auto-save on every change
            if element.OnChanged then
                element.OnChanged:Connect(function(val)
                    saveData[key] = JSON.wrap(val)
                    PersistSave()
                end)
            end
        end

        element.Destroy = function()
            frame:Destroy()
            for i, e in ipairs(tab.Elements) do
                if e == element then table.remove(tab.Elements, i) break end
            end
            if #tab.Elements == 0 then emptyState.Visible = true end
        end

        element.SetVisible = function(visible)
            frame.Visible = visible
        end

        -- Dims + overlays when disabled; restores when re-enabled.
        element.SetEnabled = function(enabled)
            local overlay = frame:FindFirstChild("_DisabledOverlay")
            if enabled then
                if overlay then overlay:Destroy() end
                Tween(frame, {BackgroundTransparency = 0}, 0.15)
                for _, lbl in ipairs(frame:GetDescendants()) do
                    if lbl:IsA("TextLabel") or lbl:IsA("TextButton") or lbl:IsA("TextBox") then
                        local stored = lbl:GetAttribute("_origColor")
                        if stored then
                            local r, g, b = stored:match("([^,]+),([^,]+),([^,]+)")
                            lbl.TextColor3 = Color3.new(tonumber(r), tonumber(g), tonumber(b))
                        end
                    end
                end
            else
                for _, lbl in ipairs(frame:GetDescendants()) do
                    if lbl:IsA("TextLabel") or lbl:IsA("TextButton") or lbl:IsA("TextBox") then
                        if not lbl:GetAttribute("_origColor") then
                            local c = lbl.TextColor3
                            lbl:SetAttribute("_origColor",
                                string.format("%.6f,%.6f,%.6f", c.R, c.G, c.B))
                        end
                        Tween(lbl, {TextColor3 = Aurora.Config.Theme.Border}, 0.15)
                    end
                end
                if not overlay then
                    overlay = Create("TextButton", {
                        Name                   = "_DisabledOverlay",
                        Parent                 = frame,
                        Size                   = UDim2.new(1, 0, 1, 0),
                        BackgroundColor3       = Aurora.Config.Theme.Background,
                        BackgroundTransparency = 0.5,
                        BorderSizePixel        = 0,
                        ZIndex                 = 99,
                        Text                   = "",
                        AutoButtonColor        = false,
                    })
                    AddCorner(overlay, UDim.new(0, 4))
                end
            end
        end

        return element
    end

    -- ── Outside-click helper ──────────────────────────────────────────────
    -- Returns a connection that calls `callback` when a mouse/touch down
    -- event fires anywhere outside `targetFrame`.  The connection is also
    -- stored in windowConnections so it is cleaned up with the window.
    local function OnClickOutside(targetFrame, callback)
        local conn = UserInputService.InputBegan:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.MouseButton1
            and inp.UserInputType ~= Enum.UserInputType.Touch then return end

            -- GuiService:GetGuiObjectsAtPosition is executor-safe
            -- Fall back to AbsolutePosition bounds check
            local ap  = targetFrame.AbsolutePosition
            local as  = targetFrame.AbsoluteSize
            local mp  = inp.Position
            local inside = mp.X >= ap.X and mp.X <= ap.X + as.X
                       and mp.Y >= ap.Y and mp.Y <= ap.Y + as.Y
            if not inside then
                callback()
            end
        end)
        table.insert(windowConnections, conn)
        return conn
    end

    -- ── Tooltip helper ────────────────────────────────────────────────────
    -- Attaches a hover tooltip to any GuiObject.
    -- The tooltip floats above the element (flips below if too close to top).
    -- A 0.5s hover delay prevents it flashing on fast mouse passes.
    -- FIX: keep tooltipLabel as a plain Lua local — Roblox Instances do not
    --      allow arbitrary keys to be set on them directly.
    local tooltipFrame = Create("Frame", {
        Name                   = "_AuroraTooltip",
        Parent                 = ScreenGui,
        Size                   = UDim2.new(0, 10, 0, 26),
        BackgroundColor3       = Aurora.Config.Theme.Surface,
        BorderSizePixel        = 0,
        Visible                = false,
        ZIndex                 = 200,
    })
    AddCorner(tooltipFrame, UDim.new(0, 4))
    Create("UIStroke", {
        Parent          = tooltipFrame,
        Color           = Aurora.Config.Theme.Border,
        Thickness       = 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
    Create("UIPadding", {
        Parent        = tooltipFrame,
        PaddingLeft   = UDim.new(0, 8),
        PaddingRight  = UDim.new(0, 8),
        PaddingTop    = UDim.new(0, 4),
        PaddingBottom = UDim.new(0, 4),
    })
    -- Plain Lua local — NOT stored on the Instance
    local tooltipLabel = Create("TextLabel", {
        Name                   = "Label",
        Parent                 = tooltipFrame,
        Size                   = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text                   = "",
        TextColor3             = Aurora.Config.Theme.TextMuted,
        Font                   = Aurora.Config.Font,
        TextSize               = 12,
        TextWrapped            = false,
        ZIndex                 = 201,
    })

    -- Moves the shared tooltip frame near the given GuiObject
    local function PositionTooltip(anchor)
        local ap = anchor.AbsolutePosition
        local as = anchor.AbsoluteSize
        local ts = tooltipFrame.AbsoluteSize
        local x  = ap.X
        local y  = ap.Y - ts.Y - 6     -- default: above the element
        if y < 4 then
            y = ap.Y + as.Y + 6        -- flip below if too close to top
        end
        tooltipFrame.Position = UDim2.new(0, x, 0, y)
    end

    -- Attach a tooltip string to any GuiObject.
    -- Called from RegisterElement when cfg.Tooltip is set.
    local tooltipThread  -- pending show-delay task handle
    local function AttachTooltip(anchor, text)
        anchor.MouseEnter:Connect(function()
            tooltipThread = task.delay(0.5, function()
                tooltipLabel.Text = text   -- uses the plain Lua local
                local textSize = game:GetService("TextService"):GetTextSize(
                    text, 12, Aurora.Config.Font, Vector2.new(400, 100))
                tooltipFrame.Size                  = UDim2.new(0, textSize.X + 16, 0, textSize.Y + 8)
                PositionTooltip(anchor)
                tooltipFrame.Visible               = true
                tooltipFrame.BackgroundTransparency = 1
                Tween(tooltipFrame, {BackgroundTransparency = 0}, 0.15)
            end)
        end)
        anchor.MouseLeave:Connect(function()
            if tooltipThread then
                task.cancel(tooltipThread)
                tooltipThread = nil
            end
            tooltipFrame.Visible = false
        end)
        anchor.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                tooltipFrame.Visible = false
            end
        end)
    end
    --  Each receives (tabContent, cfg) and returns a raw element table.
    --  Tab:CreateXxx() calls the builder then RegisterElement().
    -- ─────────────────────────────────────────────────────────────────────

    local Builders = {}

    -- ── Button ────────────────────────────────────────────────────────────

    function Builders.Button(tabContent, cfg)
